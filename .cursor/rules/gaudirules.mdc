## Common Patterns

### Backend API Pattern

**✅ CORRECT Pattern (Route → Service → CRUD):**

```python
# Route Layer (api/routes/user.py)
@router.post("/users", response_model=StandardResponse[User])
async def create_user(
    user_data: UserCreate,
    db: AsyncSession = Depends(get_db),
    current_user: User = Depends(get_current_user)
):
    service = UserService(db)
    new_user = await service.create_user(user_data)
    return created_response(data=new_user)

# Service Layer (services/user_service.py)
class UserService:
    def __init__(self, db: AsyncSession):
        self.db = db
        self.crud = UserCRUD(db)
    
    async def create_user(self, user_data: UserCreate) -> User:
        existing_user = await self.crud.get_by_email(user_data.email)
        if existing_user:
            raise ConflictError("User with this email already exists")
        
        hashed_password = hash_password(user_data.password)
        user_dict = user_data.dict()
        user_dict['password'] = hashed_password
        
        return await self.crud.create(user_dict)

# CRUD Layer (database/user/crud.py)
class UserCRUD:
    def __init__(self, db: AsyncSession):
        self.db = db
    
    async def create(self, user_data: dict) -> User:
        new_user = User(**user_data)
        self.db.add(new_user)
        await self.db.commit()
        await self.db.refresh(new_user)
        return new_user
    
    async def get_by_email(self, email: str) -> User | None:
        result = await self.db.execute(
            select(User).where(User.email == email)
        )
        return result.scalar_one_or_none()
```

**❌ WRONG Patterns (NEVER do this):**

```python
# WRONG: Business logic in route
@router.post("/users")
async def create_user(user_data: UserCreate, db: AsyncSession = Depends(get_db)):
    if await db.execute(select(User).where(User.email == user_data.email)):
        raise HTTPException(409, "Email exists")  # Business logic in route!
    hashed = hash_password(user_data.password)  # Business logic in route!
    user = User(email=user_data.email, password=hashed)
    db.add(user)
    await db.commit()
    return user

# WRONG: Route calling CRUD directly
@router.post("/users")
async def create_user(user_data: UserCreate, db: AsyncSession = Depends(get_db)):
    crud = UserCRUD(db)
    return await crud.create(user_data.dict())  # Missing business logic!

# WRONG: Business logic in CRUD
class UserCRUD:
    async def create(self, user_data: dict) -> User:
        if await self.db.execute(select(User).where(User.email == user_data['email'])):
            raise ValueError("Email exists")  # Business logic in CRUD!
        hashed = hash_password(user_data['password'])  # Business logic in CRUD!
        user_data['password'] = hashed
        # ...
```

### Frontend Component Pattern

**✅ CORRECT Pattern (View → Service → API):**

```vue
<!-- View Layer (views/UsersView.vue) -->
<template>
  <div class="container">
    <DataTable
      :columns="columns"
      :data="users"
      :loading="loading"
      :actions="actions"
      @action="handleAction"
    />
  </div>
</template>

<script>
import DataTable from '../components/ui/DataTable.vue'
import { showToast } from '../components/ui/Toast.vue'
import * as userService from '../services/userService.js'
import { extractErrorMessage } from '../utils/api/responseHandler.js'

export default {
  components: { DataTable },
  data() {
    return {
      users: [],
      loading: false,
      columns: [
        { key: 'username', label: this.$t('form.username'), sortable: true },
        { key: 'email', label: this.$t('form.email'), sortable: true }
      ],
      actions: [
        { key: 'edit', type: 'edit', icon: 'bi bi-pencil', title: this.$t('tooltip.edit') },
        { key: 'delete', type: 'delete', icon: 'bi bi-trash', title: this.$t('tooltip.delete') }
      ]
    }
  },
  async mounted() {
    await this.fetchUsers()
  },
  methods: {
    async fetchUsers() {
      this.loading = true
      try {
        this.users = await userService.getAllUsers()
      } catch (error) {
        showToast(extractErrorMessage(error), 'error')
      } finally {
        this.loading = false
      }
    },
    handleAction({ type, row }) {
      if (type === 'edit') {
        this.editUser(row)
      } else if (type === 'delete') {
        this.deleteUser(row.id)
      }
    },
    async deleteUser(id) {
      if (!confirm(this.$t('modal.confirm_delete'))) return
      try {
        await userService.deleteUser(id)
        showToast(this.$t('success.deleted'), 'success')
        await this.fetchUsers()
      } catch (error) {
        showToast(extractErrorMessage(error), 'error')
      }
    }
  }
}
</script>
```

**Service Layer (services/userService.js):**
```javascript
import apiClient from '../utils/api/client.js'
import { API_ENDPOINTS } from '../config/api.js'
import { extractData } from '../utils/api/responseHandler.js'

export const getAllUsers = async () => {
  const response = await apiClient.get(API_ENDPOINTS.USERS_ALL)
  return extractData(response)
}

export const deleteUser = async (id) => {
  const response = await apiClient.delete(API_ENDPOINTS.USER_BY_ID(id))
  return extractData(response)
}
```

